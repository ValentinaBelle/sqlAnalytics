# TOP-5 FAILING GATEWAYS (critical monitoring) 
SELECT 
  gateway,
  COUNT(*) as fail_count,
  ROUND(AVG(response_time), 2) as avg_response_s,
  SUM(amount) as failed_volume_rub
FROM transactions 
WHERE status = 'fail' 
  AND created_at >= CURDATE() - INTERVAL 7 DAY
GROUP BY gateway 
ORDER BY fail_count DESC 
LIMIT 5;

# CHANNEL SUCCESS RATE (%)  
SELECT 
  channel,
  COUNT(*) as total_tx,
  SUM(CASE WHEN status='success' THEN 1 ELSE 0 END) as success_tx,
  ROUND(SUM(CASE WHEN status='success' THEN 1 ELSE 0 END)*100.0/COUNT(*), 2) as success_rate_pct
FROM transactions 
WHERE created_at >= CURDATE() - INTERVAL 7 DAY
GROUP BY channel 
HAVING total_tx > 100
ORDER BY success_rate_pct ASC;

# 503 TIMEOUT ANALYSIS (real incident case)

SELECT 
  DATE(created_at) as incident_date,
  HOUR(created_at) as hour_peak,
  COUNT(*) as timeout_count,
  ROUND(AVG(response_time), 1) as avg_slowdown_s
FROM transactions 
WHERE error_code = '503' 
  AND response_time > 30
  AND created_at >= CURDATE() - INTERVAL 7 DAY
GROUP BY DATE(created_at), HOUR(created_at)
ORDER BY timeout_count DESC
LIMIT 10;
